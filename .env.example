# =============================================================================
# DETAIL APP — Environment Variables
# =============================================================================
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env no controle de versão
# =============================================================================

# ─── Geral ───────────────────────────────────────────────────────────────────
APP_NAME=Detail App
APP_ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ─── Banco de Dados ───────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=detailapp
POSTGRES_USER=detailapp
POSTGRES_PASSWORD=sua_senha_segura_aqui
DATABASE_URL=postgresql+asyncpg://detailapp:sua_senha_segura_aqui@localhost:5432/detailapp

# ─── Autenticação JWT ─────────────────────────────────────────────────────────
# Gere uma chave secreta com: openssl rand -hex 64
SECRET_KEY=troque_por_uma_chave_secreta_muito_longa_e_aleatoria_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Obtenha em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=seu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_google_client_secret

# ─── E-mail (SMTP) ───────────────────────────────────────────────────────────
# Configurações para SendGrid, Gmail, etc.
MAIL_USERNAME=seu_email@gmail.com
MAIL_PASSWORD=sua_senha_de_app
MAIL_FROM=noreply@detailapp.com
MAIL_FROM_NAME=Detail App
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ─── Uploads ─────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760  # 10MB em bytes
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp,gif

# ─── Redis (opcional - para cache e filas) ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── WhatsApp (futuro) ───────────────────────────────────────────────────────
# Twilio ou Meta API - configure quando disponível
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Segurança ───────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=24
