{
  "version": 2,
  "outputDirectory": "frontend/dist",
  "installCommand": "pip install --break-system-packages -r requirements.txt && cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
